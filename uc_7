class HelloApp {
    public static void main(String[] args) {

        // No arguments case
        if (args.length == 0) {
            System.out.println("Hello, World!");
            return;
        }

        String result = "Hello ";

        // Enhanced for loop
        for (String name : args) {
            result = result.concat(name).concat(", ");
        }

        // Remove trailing ", "
        result = result.substring(0, result.length() - 2);

        System.out.println(result);
    }
}
